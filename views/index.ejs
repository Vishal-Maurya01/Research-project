<%- include('layouts/header.ejs') %>
    <% const selectedCategory=req.query.category; %>
        <div class="mobile-search">
            <button class="search-btn"><i class="fa-solid fa-magnifying-glass"></i></button>
            <input type="search" name="item" id="search-box" placeholder="Search for items">
            <div class="filter"><i class="fa-solid fa-sliders"></i></div>
        </div>
        <div class="main">
            <div class="shop-page1">
                <div class="category-section">
                    <div class="category-box drag-scroll">
                        <!-- Electronics -->
                        <a href="/category/Electronics" class="card-link">
                            <div class="category electronic">
                                <img src="https://images.unsplash.com/photo-1652721367098-0ecad4cc0370?q=80&w=464&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="" srcset="">
                            </div>
                        </a>
                        <!-- Fashion -->
                        <a href=" /category/Fashion" class="card-link">
                                <div class="category fashion">
                                    <img src="https://images.unsplash.com/photo-1600269452121-4f2416e55c28?q=80&w=465&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="" srcset="">
                                </div>
                        </a>
                        <!-- Grocery -->
                        <a href="/category/Grocery" class="card-link">
                            <div class="category grocery">
                                <img src="https://images.unsplash.com/photo-1590779033100-9f60a05a013d?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mnx8dmVnZXRhYmxlc3xlbnwwfHwwfHx8MA%3D%3D"  alt="" srcset="">
                            </div>
                        </a>
                        <!-- Beauty -->
                        <a href="/category/Beauty" class="card-link">
                            <div class="category beauty">
                                <img src="https://images.unsplash.com/photo-1608979048467-6194dabc6a3d?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8N3x8YmVhdXR5JTIwcHJvZHVjdHN8ZW58MHx8MHx8fDA%3D" alt="" srcset="">
                            </div>
                        </a>
                        <!-- Toy -->
                        <a href="/category/Toys" class="card-link">
                            <div class="category toys">
                                <img src="https://images.unsplash.com/photo-1583531681157-1b227e61b3bf?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mnx8d2hlZWwlMjB0b3l8ZW58MHx8MHx8fDA%3D" alt="" srcset="">
                            </div>
                        </a>
                        <a href="/category/Sports" class="card-link">
                            <div class="category sports">
                                <img src="https://plus.unsplash.com/premium_photo-1678444760880-95b334f09e2e?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MXx8c3BvcnRzJTIwcHJvZHVjdHN8ZW58MHx8MHx8fDA%3D" alt="">
                            </div>
                        </a>
                        <a href="/category/Books" class="card-link">
                            <div class="category books">
                                <img src="https://images.unsplash.com/photo-1497633762265-9d179a990aa6?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTB8fGJvb2tzfGVufDB8fDB8fHww" alt="" srcset="">
                            </div>
                        </a>
                        <a href="/category/Jewellery" class="card-link">
                            <div class="category jewellery">
                                <img src="https://images.unsplash.com/photo-1631560230221-faff391fd241?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8M3x8amV3ZWxsZXJ5JTIwaXRtZXN8ZW58MHx8MHx8fDA%3D" alt="">
                            </div>
                        </a>
                        <a href="/category/Footwear" class="card-link">
                            <div class="category footwear">
                                <img src="https://images.unsplash.com/photo-1603808033192-082d6919d3e1?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8NHx8Zm9vdHdlYXJ8ZW58MHx8MHx8fDA%3D" alt="">
                            </div>
                        </a>
                    </div>
                </div>
                <div class="top-deal-slider">
                    <div class="slider-track">
                        <div class="deal deal-1">
                            <img src="/images/smartphones.jpeg" alt="smartphones">
                        </div>
                        <div class="deal deal-2">
                            <img src="/images/beauty_product.jpeg" alt="beauty">
                        </div>
                        <div class="deal deal-3">
                            <img src="/images/toys.jpeg" alt="toys">
                        </div>
                        <div class="deal deal-4">
                            <img src="/images/tvs.jpeg" alt="tvs">
                        </div>
                    </div>
                </div>
                <div class="trending_product">
                    <h1>Trending Items</h1>
                    <div class="top_product drag-scroll">
                        <% trendingItems.forEach(item=> { %>
                            <a href="/product/<%= item._id %>" class="card-link">
                                <div class="top_product_item">
                                    <img src="<%= item.image %>" alt="<%= item.name %>">
                                    <h4>
                                        <%= item.name %>
                                    </h4>
                                    <p class="price">₹<%= item.price %>
                                    </p>
                                </div>
                            </a>
                            <% }) %>
                    </div>
                </div>
            </div>
            <div class="shop-page2">
                <div class="all-product">
                    <h2>All Products</h2>
                    <div class="shopping-container">
                        <% allItems.forEach(item=> { %>
                            <div class="product-card">
                                <a href="/product/<%= item._id %>">
                                    <img src="<%= item.image %>" alt="<%= item.name %>">
                                    <h4>
                                        <%= item.name %>
                                    </h4>
                                    <p class="price">₹<%= item.price %>
                                    </p>
                                </a>
                            </div>
                            <% }) %>
                    </div>
                </div>

            </div>
        </div>

        <%- include('layouts/footer.ejs') %>