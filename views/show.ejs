<%- include('layouts/header.ejs') %>
    <div class="product-detail">
        <!-- LEFT IMAGE -->
        <div class="product-image">
            <img src="<%= product.image %>" alt="">
        </div>

        <!-- RIGHT DETAILS -->
        <div class="product-info">
            <h1>
                <%= product.name %>
            </h1>
            <p class="brand">Brand: <%= product.brand %>
            </p>
            <h2 class="price">₹<%= product.price %>
            </h2>
            <p class="desc">
                <%= product.description %>
            </p>

            <!-- Rating -->
            <p>⭐ <%= avgRating %> / 5</p>

            <!-- Quantity -->
            <div class="quantity-box">
                <button onclick="decrease()">-</button>
                <input type="text" id="qty" value="1" readonly>
                <button onclick="increase()">+</button>
            </div>

            <!-- Add to Cart -->
            <div class="btn-group">
                <a href="/add-to-cart/<%= product._id %>" class="add-cart">
                    🛒 Add to Cart
                </a>

                <a href="/checkout/<%= product._id %>" class="buy-btn">
                    ⚡ Buy Now
                </a>
                <a href="/wishlist/<%= product._id %>" class="wishlist-btn">
                    ❤️ Add to Wishlist
                </a>
            </div>
        </div>

    </div>

    <hr>

    <form action="/product/<%= product._id %>/review" method="POST" style="margin-bottom: 10px; padding: 2vw;">
        <h3>Give Your Review</h3>
        <label>Rating:</label>
        <select name="rating">
            <option value="5">⭐⭐⭐⭐⭐</option>
            <option value="4">⭐⭐⭐⭐</option>
            <option value="3">⭐⭐⭐</option>
            <option value="2">⭐⭐</option>
            <option value="1">⭐</option>
        </select>
        <br><br>
        <textarea name="comment" placeholder="Write your feedback..." required></textarea>

        <br><br>
        <button type="submit">Submit Review</button>
    </form>

    <hr>
    <div class="show-review" style="margin-bottom: 10px; padding: 2vw;">
        <h3>Customer Reviews</h3>
        <% if(product.reviews.length===0){ %>
            <p>No reviews yet</p>
            <% } %>
                <% product.reviews.forEach(r=> { %>
                    <div class="review-box">
                        <p><strong>
                                <%= r.user %>
                            </strong></p>
                        <p>⭐ <%= r.rating %>/5</p>
                        <p>
                            <%= r.comment %>
                        </p>
                    </div>
                    <% }) %>
    </div>
    <hr>
    <!-- RECOMMENDED -->
    <div class="trending_product">
        <h2>Recommended Products</h2>
        <div class="top_product drag-scroll">
            <% relatedProducts.forEach(item=> { %>
                <a href="/product/<%= item._id %>" class="card-link">
                    <div class="top_product_item">
                        <img src="<%= item.image %>" alt="">
                        <h4>
                            <%= item.name %>
                        </h4>
                        <p class="price">₹<%= item.price %>
                        </p>
                    </div>
                </a>
                <% }) %>
        </div>
    </div>

    <script>
        function increase() {
            let qty = document.getElementById("qty");
            qty.value = parseInt(qty.value) + 1;
        }

        function decrease() {
            let qty = document.getElementById("qty");
            if (qty.value > 1) {
                qty.value = parseInt(qty.value) - 1;
            }
        }
    </script>

    <%- include('layouts/footer.ejs') %>